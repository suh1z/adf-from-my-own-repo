{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-online23"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageonline23.dfs.core.windows.net/"
		},
		"AzureDatabricksLink_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0312-220547-zolnbabl"
		},
		"FaceitAPI_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://open.faceit.com/data/v4"
		},
		"RestService1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://open.faceit.com/data/v4/players?nickname=suh1na"
		},
		"faceitApiKey_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-online23.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-online23_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureDatabricksLink_properties_typeProperties_existingClusterId": {
						"value": "[parameters('AzureDatabricksLink_properties_typeProperties_existingClusterId')]"
					},
					"faceitApiKey_properties_typeProperties_baseUrl": {
						"value": "[parameters('faceitApiKey_properties_typeProperties_baseUrl')]"
					},
					"FaceitAPI_properties_typeProperties_url": {
						"value": "[parameters('FaceitAPI_properties_typeProperties_url')]"
					},
					"RestService1_properties_typeProperties_url": {
						"value": "[parameters('RestService1_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}