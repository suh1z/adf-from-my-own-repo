						"inputs": [
							{
								"referenceName": "FaceitAPI_playerHistory",
								"type": "DatasetReference",
								"parameters": {
									"player_id": {
										"value": "@pipeline().parameters.user_id",
										"type": "Expression"
									}
								}
							}
						],
						"outputs": [
							{
								"referenceName": "FaceitAPI_PlayerBlob",
								"type": "DatasetReference",
								"parameters": {
									"player_id": {
										"value": "@concat(pipeline().parameters.user_id, '_history')",
										"type": "Expression"
									}
								}
							}
						]
					},
					{
						"name": "silver-player-history",
						"type": "DatabricksNotebook",
						"dependsOn": [
							{
								"activity": "Get-Player-History",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"notebookPath": "/Users/jonatan.holmberg@abo.fi/adf-from-my-own-repo/notebooks/silver-player-history",
