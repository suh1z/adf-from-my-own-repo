						},
						"linkedServiceName": {
							"referenceName": "AzureDatabricksLink",
							"type": "LinkedServiceReference",
							"parameters": {
								"player_id": {
									"value": "@pipeline().parameters.user_id",
									"type": "Expression"
								}
							}
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"parameters": {
					"user_id": {
						"type": "string"
					}
				},
				"variables": {
					"user_id": {
						"type": "String"
					}
